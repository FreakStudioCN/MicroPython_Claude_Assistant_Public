{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pythonw \"${CLAUDE_PLUGIN_ROOT}/daemon/hook_bridge.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "pythonw \"${CLAUDE_PLUGIN_ROOT}/daemon/hook_bridge.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "pythonw \"${CLAUDE_PLUGIN_ROOT}/daemon/hook_bridge.py\""
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "pythonw \"${CLAUDE_PLUGIN_ROOT}/daemon/hook_bridge.py\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pythonw \"${CLAUDE_PLUGIN_ROOT}/daemon/hook_bridge.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/daemon/hook_bridge.py\""
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/daemon/hook_bridge.py\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/daemon/hook_bridge.py\""
          }
        ]
      }
    ]
  }
}
